        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="input_env" target="compile" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.8;entryY=0;entryDx=0;entryDy=0;" edge="1" source="input_llm" target="compile" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Compile → Skill IR -->
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#10739e;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;entryPerimeter=0;" edge="1" source="compile" target="skill_ir" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Compile → Gate (main flow, label S) -->
        <mxCell id="e5" value="&lt;font style=&quot;font-size: 10px;&quot; color=&quot;#6c8ebf&quot;&gt;&lt;i&gt;S&lt;/i&gt;&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="compile" target="gate" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Gate → Execute (PASS, green) -->
        <mxCell id="e6" value="&lt;font color=&quot;#2E7D32&quot; style=&quot;font-size: 11px;&quot;&gt;&lt;b&gt;PASS ✓&lt;/b&gt;&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2E7D32;strokeWidth=2.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="gate" target="execute" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Gate → Safety Report (BLOCK, red dashed) -->
        <mxCell id="e7" value="&lt;font color=&quot;#C62828&quot; style=&quot;font-size: 11px;&quot;&gt;&lt;b&gt;BLOCK ✗&lt;/b&gt;&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#C62828;strokeWidth=2;dashed=1;exitX=0;exitY=0.8;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="gate" target="safety_report" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Execute → Verify (label τ) -->
        <mxCell id="e8" value="&lt;font style=&quot;font-size: 10px;&quot; color=&quot;#455A64&quot;&gt;&lt;i&gt;τ&lt;/i&gt;&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=0.3;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="execute" target="verify" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Verify → Optimize (Fail, orange) -->
        <mxCell id="e9" value="&lt;font color=&quot;#E65100&quot; style=&quot;font-size: 11px;&quot;&gt;&lt;b&gt;Fail&lt;/b&gt;&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#E65100;strokeWidth=2.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="verify" target="optimize" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Verify → Skill Bank (Success, green, bottom route) -->
