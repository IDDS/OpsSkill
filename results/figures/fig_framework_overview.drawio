        <mxCell id="phase_execute" value="&lt;font color=&quot;#C62828&quot; style=&quot;font-size: 12px;&quot;&gt;&lt;b&gt;执行阶段 · Execution Phase (Deterministic Pipeline)&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;dashPattern=8 4;fillColor=none;strokeColor=#C62828;strokeWidth=2;verticalAlign=top;align=left;spacingLeft=10;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="30" y="310" width="660" height="425" as="geometry"/>
        </mxCell>

        <!-- ==================== INPUTS (Green) ==================== -->
        <mxCell id="input_task" value="&lt;b&gt;任务卡&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;Task Card&lt;br&gt;&lt;i&gt;x = (d, c, g, Ω, 𝒯)&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="50" y="82" width="180" height="62" as="geometry"/>
        </mxCell>

        <mxCell id="input_env" value="&lt;b&gt;环境能力画像&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;Env Capability Profile&lt;br&gt;&lt;i&gt;κ(E) = (κ_rbac, κ_res, ...)&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="255" y="82" width="200" height="62" as="geometry"/>
        </mxCell>

        <mxCell id="input_llm" value="&lt;b&gt;LLM 编译器&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;LLM Compiler&lt;br&gt;&lt;i&gt;f_θ (DeepSeek-V3)&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="480" y="82" width="185" height="62" as="geometry"/>
        </mxCell>

        <!-- ==================== COMPILE (Blue) ==================== -->
        <mxCell id="compile" value="&lt;b&gt;① 约束感知技能编译&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;Constraint-Aware Skill Compilation: &lt;i&gt;f_θ(x, κ(E)) → S&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="130" y="200" width="400" height="68" as="geometry"/>
        </mxCell>

        <!-- ==================== TYPED SKILL IR (Cyan cylinder) ==================== -->
        <mxCell id="skill_ir" value="&lt;b style=&quot;font-size: 14px;&quot;&gt;Typed Skill IR&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;&lt;i&gt;S = (P, A, V, R, ρ, η)&lt;/i&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size: 9px;&quot; color=&quot;#555&quot;&gt;前置条件 · 动作序列 · 验证器&lt;br&gt;回滚计划 · 风险标注 · 元数据&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#b1ddf0;strokeColor=#10739e;strokeWidth=2;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="755" y="135" width="230" height="120" as="geometry"/>
        </mxCell>

        <!-- ==================== GATE (Orange, thick border) ==================== -->
        <mxCell id="gate" value="&lt;b&gt;② 风险预算门控执行&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;Risk-Budget Gated Execution&lt;br&gt;&lt;i&gt;Precond ✓ · Risk ≤ b_max · Policy ✓&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=3;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="130" y="340" width="400" height="72" as="geometry"/>
        </mxCell>

        <!-- Safety Report (note shape) -->
        <mxCell id="safety_report" value="&lt;font color=&quot;#C62828&quot;&gt;&lt;b&gt;安全报告&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;Safety Report&lt;/font&gt;&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#FFCDD2;strokeColor=#C62828;strokeWidth=1.5;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="35" y="430" width="100" height="50" as="geometry"/>
        </mxCell>

        <!-- ==================== EXECUTE (Pink) ==================== -->
        <mxCell id="execute" value="&lt;b&gt;③ 受控执行器&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;Controlled Executor: &lt;i&gt;Execute A → trace τ = [(a_i, o_i)]&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="130" y="475" width="400" height="68" as="geometry"/>
        </mxCell>

        <!-- ==================== VERIFY (Purple) ==================== -->
        <mxCell id="verify" value="&lt;b&gt;④ 隐藏多信号验证&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;Hidden Multi-Signal Verify&lt;br&gt;&lt;i&gt;V_vis(τ) + V_hid(τ)&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="45" y="600" width="280" height="68" as="geometry"/>
        </mxCell>

        <!-- ==================== OPTIMIZE (Yellow) ==================== -->
        <mxCell id="optimize" value="&lt;b&gt;⑤ 结构化失败驱动优化&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;Failure-Driven Optimization&lt;br&gt;&lt;i&gt;σ → Δ_σ(S) → S'&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="355" y="600" width="280" height="68" as="geometry"/>
        </mxCell>

        <!-- ==================== SKILL BANK (Cyan cylinder) ==================== -->
        <mxCell id="skill_bank" value="&lt;b style=&quot;font-size: 14px;&quot;&gt;技能银行&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Skill Bank&lt;br&gt;&lt;i&gt;积累与复用&lt;/i&gt;&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#b1ddf0;strokeColor=#10739e;strokeWidth=2;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="770" y="510" width="200" height="95" as="geometry"/>
        </mxCell>

        <!-- ========================================================= -->
        <!-- ====================== EDGES ============================ -->
        <!-- ========================================================= -->

        <!-- Inputs → Compile -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.2;entryY=0;entryDx=0;entryDy=0;" edge="1" source="input_task" target="compile" parent="1">
