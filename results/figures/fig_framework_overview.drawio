        <!-- ==================== PHASE GROUPING BOXES ==================== -->
        <mxCell id="phase_compile" value="&lt;font color=&quot;#1565C0&quot; style=&quot;font-size: 12px;&quot;&gt;&lt;b&gt;编译阶段 · Compile Phase (LLM-Assisted)&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;dashPattern=8 4;fillColor=none;strokeColor=#1565C0;strokeWidth=2;verticalAlign=top;align=left;spacingLeft=10;spacingTop=5;" vertex="1" parent="1">
